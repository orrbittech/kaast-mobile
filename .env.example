EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Clerk Account Portal user profile URL (from Dashboard > Account Portal > Pages)
EXPO_PUBLIC_CLERK_ACCOUNT_PORTAL_URL=https://accounts.dev/user
# Clerk Account Portal organization billing URL (Dashboard > Account Portal > Pages)
EXPO_PUBLIC_CLERK_ACCOUNT_PORTAL_BILLING_URL=https://accounts.dev/organization/billing
# Web app bridge — Account Portal redirect_url (NOT the accounts.dev host)
EXPO_PUBLIC_MOBILE_BILLING_RETURN_URL=https://kaast.app/mobile/billing-return
# API base URL (must be reachable from device/emulator)
EXPO_PUBLIC_API_URL=http://localhost:4400

# Web billing page URL (TV on-screen copy and server email links)
EXPO_PUBLIC_BILLING_URL=https://kaast.app/billing

# SECURITY: Do NOT add CLERK_SECRET_KEY to the APK. The secret key belongs only on the server.
