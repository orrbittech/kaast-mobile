{
  "expo": {
    "name": "KAAST",
    "slug": "kaast-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apk",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaast.mobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.kaast.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#171717",
          "dark": {
            "backgroundColor": "#171717"
          }
        }
      ],
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Use Face ID to sign in quickly"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to sign in quickly"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#DD2C2C",
          "sounds": []
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KAAST to access your photos and videos for media uploads.",
          "cameraPermission": "Allow KAAST to use the camera for media uploads."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/a8153e03-1206-42e4-b664-79584f6a62b5",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a8153e03-1206-42e4-b664-79584f6a62b5"
      }
    },
    "owner": "legendssoftware"
  }
}
